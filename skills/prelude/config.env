# Prelude skill — shared team configuration.
#
# Checked into the repo so every teammate gets the same defaults after
# `git pull`. Per-machine overrides still win: any PRELUDE_* variable
# already set in the shell before invoking `scripts/sync.sh` takes
# precedence (this file only sets defaults if unset).
#
# Transport: the team-shared context server.
#   - Laptop / WAN: http://10.15.33.50:8002  (integrated Prelude instance)
#   - sync.sh auto-detects the server type:
#       * Prelude FastAPI backend  -> /api/wiki/lookup/list/<key>           (preferred)
#         (note: /api/wiki/... is Prelude's HTTP API namespace — not a skill concept)
#       * legacy flat-files server -> /<key>/manifest.json + /<key>/pages/  (fallback)
#   - Keyed by {repo_type}__{owner}__{repo}__{language}.
#
# To use your own locally-generated context instead (the dev loop on the
# generator machine), export PRELUDE_SOURCE before running the skill, e.g.
#   export PRELUDE_SOURCE=file://$HOME/.prelude/wikicache/local__local__fortincm_webservice__en
#   (the $HOME/.prelude/wikicache path is Prelude's on-disk location; not a skill rename target)
: "${PRELUDE_DEFAULT_KEY:=local__local__fortincm__en}"
: "${PRELUDE_SOURCE:=http://10.15.33.50:8002}"
export PRELUDE_DEFAULT_KEY PRELUDE_SOURCE
